{
  "ConnectionStrings": {
    "DefaultConnection": "Host=$_DB_HOST_$;Port=$_DB_PORT_$;Database=$_DB_NAME_$;Username=$_DB_USER_$;Password=$_DB_PASSWORD_$;Pooling=true;Connection Idle Lifetime=60;"
  },
  "AzureAd": {
    "Instance": "$_AZURE_AD_INSTANCE_$",
    "Domain": "$_AZURE_AD_DOMAIN_$",
    "TenantId": "$_AZURE_AD_TENANT_ID_$",
    "ClientId": "$_AZURE_AD_CLIENT_ID_$",
    "Scopes": "access_as_user",
    "CallbackPath": "/signin-oidc"
  },
  "Jwt": {
    "SecretKey": "$_JWT_SECRET_KEY_$",
    "Issuer": "DigmusCandidate.API",
    "Audience": "DigmusCandidate.Client",
    "TokenLifetimeMinutes": 60
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "ApplicationName": "Dignus.Candidate.API"
    }
  },
  "TestSettings": {
    "QuestionCounts": {
      "Portuguese": 10,
      "Math": 15,
      "Psychology": 12,
      "VisualRetention": 8
    },
    "TestTimeouts": {
      "Portuguese": 30,
      "Math": 45,
      "Psychology": 25,
      "VisualRetention": 20
    },
    "MathTest": {
      "QuestionCount": 2,
      "TimeoutMinutes": 45,
      "AllowVideoUpload": true,
      "VideoRequiredPerQuestion": true,
      "Questions": [
        {
          "Number": 1,
          "Text": "Um produto teve seu preço aumentado em 20% e depois diminuído em 15%. Se o preço final é R$ 102,00, qual era o preço original?",
          "Type": "calculation",
          "ExpectedAnswerType": "numeric",
          "AllowedTimeMinutes": 22
        },
        {
          "Number": 2,
          "Text": "Uma empresa produz 1200 unidades por dia. Se aumentar a produção em 25% no primeiro mês e depois reduzir em 10% no segundo mês, qual será a produção diária final?",
          "Type": "calculation",
          "ExpectedAnswerType": "numeric",
          "AllowedTimeMinutes": 23
        }
      ]
    },
    "VisualRetentionTest": {
      "QuestionCount": 8,
      "TimeoutMinutes": 20,
      "DisplayTimeSeconds": 10,
      "RecallTimeSeconds": 30,
      "Questions": [
        {
          "Number": 1,
          "PatternType": "geometric_sequence",
          "Difficulty": "easy",
          "DisplayTimeSeconds": 8
        },
        {
          "Number": 2,
          "PatternType": "color_matrix",
          "Difficulty": "easy",
          "DisplayTimeSeconds": 10
        },
        {
          "Number": 3,
          "PatternType": "number_sequence",
          "Difficulty": "medium",
          "DisplayTimeSeconds": 12
        },
        {
          "Number": 4,
          "PatternType": "geometric_transformation",
          "Difficulty": "medium",
          "DisplayTimeSeconds": 15
        },
        {
          "Number": 5,
          "PatternType": "spatial_pattern",
          "Difficulty": "medium",
          "DisplayTimeSeconds": 15
        },
        {
          "Number": 6,
          "PatternType": "complex_matrix",
          "Difficulty": "hard",
          "DisplayTimeSeconds": 18
        },
        {
          "Number": 7,
          "PatternType": "abstract_sequence",
          "Difficulty": "hard",
          "DisplayTimeSeconds": 20
        },
        {
          "Number": 8,
          "PatternType": "multi_dimensional",
          "Difficulty": "expert",
          "DisplayTimeSeconds": 25
        }
      ]
    }
  },
  "AzureStorage": {
    "ConnectionString": "$_AZURE_STORAGE_CONNECTION_STRING_$",
    "ContainerNames": {
      "Audio": "audio-submissions",
      "Video": "video-interviews"
    }
  },
  "MediaUploadSettings": {
    "MaxFileSizes": {
      "AudioMB": 50,
      "VideoMB": 500
    },
    "AllowedExtensions": {
      "Audio": [".mp3", ".wav", ".m4a", ".aac"],
      "Video": [".mp4", ".mov", ".avi", ".wmv"]
    },
    "AllowedMimeTypes": {
      "Audio": ["audio/mpeg", "audio/wav", "audio/x-m4a", "audio/aac"],
      "Video": ["video/mp4", "video/quicktime", "video/x-msvideo", "video/x-ms-wmv"]
    }
  },
  "AISettings": {
    "Google": {
      "ApiKey": "$_GOOGLE_AI_API_KEY_$",
      "TextModel": "gemini-1.5-pro",
      "AudioModel": "gemini-1.5-pro",
      "VideoModel": "gemini-1.5-pro",
      "MaxTokens": 4000,
      "Temperature": 0.7
    },
    "LangChain": {
      "VerboseLogging": false,
      "MaxRetryAttempts": 3,
      "RetryDelayMs": 1000
    },
    "Timeouts": {
      "AudioTranscriptionMinutes": 10,
      "VideoAnalysisMinutes": 15,
      "TextEvaluationMinutes": 5,
      "HttpClientSeconds": 300
    },
    "Callbacks": {
      "BaseUrl": "$_CALLBACK_BASE_URL_$",
      "SharedSecret": "$_CALLBACK_SHARED_SECRET_$",
      "EnableAuthentication": true,
      "Endpoints": {
        "AudioTranscription": "/api/ai/callback/audio-transcription",
        "VideoAnalysis": "/api/ai/callback/video-analysis",
        "EvaluationComplete": "/api/ai/callback/evaluation-complete"
      }
    }
  },
  "Databricks": {
    "WorkspaceUrl": "https://adb-5560756401129732.12.azuredatabricks.net",
    "AccessToken": "$_DATABRICKS_ACCESS_TOKEN_$",
    "ClusterId": "$_DATABRICKS_CLUSTER_ID_$",
    "GupyNotebookPath": "/Shared/gupy-integration",
    "DatabaseName": "candidates_db",
    "CandidateTableName": "gupy_candidates",
    "JobsTableName": "gupy_jobs",
    "SyncFrequencyMinutes": 60,
    "MaxRetryAttempts": 3,
    "JobTimeoutMinutes": 30,
    "EnableMonitoring": true,
    "BatchSize": 1000,
    "ConnectionTimeoutSeconds": 30
  },
  "GupyAPI": {
    "ApiBaseUrl": "https://api.gupy.io/v2",
    "ApiKey": "$_GUPY_API_KEY_$",
    "ClientId": "$_GUPY_CLIENT_ID_$",
    "ClientSecret": "$_GUPY_CLIENT_SECRET_$",
    "EnableWebhooks": true,
    "WebhookSecret": "$_GUPY_WEBHOOK_SECRET_$",
    "RateLimitRequestsPerMinute": 60,
    "DataRetentionDays": 90
  },
  "AllowedHosts": "*"
}
